# Groq API (https://console.groq.com)
GROQ_API_KEY=gsk_your_key_here

# Observability — pick ONE (or leave both blank to disable tracing)

# Option A: Langfuse (open-source, self-hostable — https://langfuse.com)
# Self-host: docker run -p 3000:3000 langfuse/langfuse
# Or use free cloud tier at cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-your_key_here
LANGFUSE_SECRET_KEY=sk-lf-your_key_here
LANGFUSE_HOST=https://cloud.langfuse.com   # or http://localhost:3000 if self-hosted
LANGFUSE_TRACING=false

# Option C: Phoenix/Arize (open-source, runs locally — pip install arize-phoenix)
# Start server: python -m phoenix.server.main --port 6006
PHOENIX_TRACING=false
PHOENIX_HOST=http://localhost:6006

# Model config
GROQ_MODEL=llama-3.3-70b-versatile

# App config
LOG_LEVEL=INFO
